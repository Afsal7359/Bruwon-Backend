# ---- Server ----
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ---- Database ----
MONGO_URI=mongodb://127.0.0.1:27017/bruwon

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES=7d

# ---- Seed admin (used by npm run seed) ----
ADMIN_NAME=Bruwon Admin
ADMIN_EMAIL=admin@bruwon.com
ADMIN_PASSWORD=admin12345

# ---- Razorpay ----
# Get keys from https://dashboard.razorpay.com/app/keys (Test Mode)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
CURRENCY=INR

# ---- Cloudinary (image uploads from the admin panel) ----
# Get these from https://console.cloudinary.com/ (Dashboard → Product Environment Credentials)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Shipping is now per-product (set on each box in the admin panel / seed).
